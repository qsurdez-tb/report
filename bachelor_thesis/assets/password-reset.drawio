        <mxCell id="2" parent="1" style="ellipse;whiteSpace=wrap;html=1;" value="POST /do/reset_password&#xa;{ email }" vertex="1">
          <mxGeometry height="50" width="200" x="260" y="30" as="geometry" />
        </mxCell>
        <mxCell id="3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Return { &quot;error&quot;: false } immediately&#xa;(constant-time response)" vertex="1">
          <mxGeometry height="50" width="200" x="260" y="130" as="geometry" />
        </mxCell>
        <mxCell id="4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Background thread&lt;br&gt;Verify email from DB" vertex="1">
          <mxGeometry height="70" width="200" x="260" y="230" as="geometry" />
        </mxCell>
        <mxCell id="5" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Email match&#xa;found?" vertex="1">
