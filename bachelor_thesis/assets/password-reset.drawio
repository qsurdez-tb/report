        </mxCell>
        <mxCell id="7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="[If email hash outdated]&#xa;Re-hash + UPDATE users.email" vertex="1">
