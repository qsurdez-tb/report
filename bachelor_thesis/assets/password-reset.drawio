        <mxCell id="10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="GET /reset_password_stage2/{token}&lt;br&gt;&lt;br&gt;Redis lookup reset_{token}&lt;br&gt;[expired/missing -&amp;gt; error]&lt;br&gt;&lt;br&gt;Serve password reset form" vertex="1">
          <mxGeometry height="110" width="200" x="260" y="750" as="geometry" />
        </mxCell>
