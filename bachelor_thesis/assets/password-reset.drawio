          <mxGeometry height="100" width="200" x="260" y="480" as="geometry" />
        </mxCell>
        <mxCell id="9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Send email to user&#xa;URL: /reset_password_stage2/{token}" vertex="1">
