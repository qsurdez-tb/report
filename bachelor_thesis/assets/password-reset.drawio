<mxfile host="app.diagrams.net">
  <diagram name="Password Reset" id="password-reset">
    <mxGraphModel dx="1821" dy="1163" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
