  <diagram name="TOTP Reset" id="totp-reset">
    <mxGraphModel dx="1377" dy="872" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" value="POST /do/reset_totp&#xa;{ email }" parent="1" vertex="1" style="ellipse;whiteSpace=wrap;html=1;">
          <mxGeometry x="260" y="30" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="3" value="Return { &quot;error&quot;: false } immediately&#xa;(constant-time response)" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;">
          <mxGeometry x="260" y="130" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="4" value="Background thread&#xa;Scan all users&#xa;PBKDF2(email).verify(users.email)" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;">
          <mxGeometry x="260" y="230" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="5" value="Email match&#xa;found?" parent="1" vertex="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;">
          <mxGeometry x="260" y="340" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="6" value="Silent end&#xa;(no email sent)" parent="1" vertex="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;">
          <mxGeometry x="510" y="350" width="150" height="40" as="geometry" />
        </mxCell>
        <mxCell id="7" value="Generate reset token&#xa;token = sha512(random_data(100))&#xa;&#xa;Redis reset DB:&#xa;SET reset_{token} → JSON payload&#xa;EX = 86400 (24h)" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;">
          <mxGeometry x="260" y="460" width="200" height="100" as="geometry" />
        </mxCell>
        <mxCell id="8" value="Send email to user&#xa;URL: /reset_totp_stage2/{token}" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;">
          <mxGeometry x="260" y="610" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="9" value="GET /reset_totp_stage2/{token}&#xa;&#xa;Redis lookup reset_{token}&#xa;[expired/missing → error]&#xa;&#xa;Generate new TOTP secret&#xa;Serve QR code + form" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;">
          <mxGeometry x="260" y="720" width="200" height="110" as="geometry" />
        </mxCell>
        <mxCell id="10" value="POST /reset_totp_stage2/{token}&#xa;{ totp: new_secret }&#xa;&#xa;UPDATE users SET totp = ?&#xa;DELETE reset_{token} from Redis" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;">
          <mxGeometry x="260" y="890" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="11" value="TOTP reset complete&#xa;(token single-use)" parent="1" vertex="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;">
          <mxGeometry x="270" y="1040" width="180" height="44" as="geometry" />
        </mxCell>
        <mxCell id="12" edge="1" parent="1" source="2" target="3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="13" edge="1" parent="1" source="3" target="4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;">
